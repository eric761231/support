<Window x:Class="LinHPMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="天堂體力監測器" Height="650" Width="450"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="天堂體力監測器" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#BB86FC"/>

            <GroupBox Header="設定" Foreground="#03DAC6" BorderBrush="#03DAC6" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="視窗標題:" VerticalAlignment="Center"/>
                        <TextBox x:Name="WindowTitleTextBox" Grid.Column="1" Text="Lineage" Background="#333333" Foreground="White" BorderBrush="#444444"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="補血點(%):" VerticalAlignment="Center"/>
                        <TextBox x:Name="ThresholdTextBox" Grid.Column="1" Text="70" Background="#333333" Foreground="White" BorderBrush="#444444"/>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="熱鍵:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="HotkeyComboBox" Grid.Column="1" Background="#333333" Foreground="White" BorderBrush="#444444">
                            <ComboBoxItem Content="F5" IsSelected="True"/>
                            <ComboBoxItem Content="F6"/>
                            <ComboBoxItem Content="F7"/>
                            <ComboBoxItem Content="F8"/>
                            <ComboBoxItem Content="F9"/>
                            <ComboBoxItem Content="F10"/>
                            <ComboBoxItem Content="F11"/>
                            <ComboBoxItem Content="F12"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="按壓(ms):" VerticalAlignment="Center"/>
                        <TextBox x:Name="DurationTextBox" Grid.Column="1" Text="50" Background="#333333" Foreground="White" BorderBrush="#444444" Margin="0,0,10,0"/>
                        <TextBlock Text="間隔(ms):" Grid.Column="2" VerticalAlignment="Center"/>
                        <TextBox x:Name="IntervalTextBox" Grid.Column="3" Text="150" Background="#333333" Foreground="White" BorderBrush="#444444"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="體力狀態" Foreground="#CF6679" BorderBrush="#CF6679" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="HPValueTextBlock" Text="0 / 0 (0%)" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <ProgressBar x:Name="HPProgressBar" Height="25" Minimum="0" Maximum="100" Value="0" Foreground="#03DAC6" Background="#333333" BorderBrush="#444444"/>
                </StackPanel>
            </GroupBox>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="StartButton" Content="開始監測" Click="StartButton_Click" Height="40" Margin="0,0,5,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0"/>
                <Button x:Name="StopButton" Content="停止監測" Click="StopButton_Click" Height="40" Margin="5,0,0,0" Background="#333333" Foreground="#BB86FC" FontWeight="Bold" BorderThickness="1" BorderBrush="#BB86FC" IsEnabled="False"/>
            </Grid>

            <TextBlock Text="執行日誌:" Margin="0,0,0,5"/>
            <TextBox x:Name="LogTextBox" Height="150" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#121212" Foreground="#888888" BorderBrush="#333333" FontFamily="Consolas"/>
        </StackPanel>
    </Grid>
</Window>
